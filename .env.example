# 飞书机器人配置示例
# 复制此文件为 .env 并填入你的实际配置

# ============================================================
# 飞书应用配置（必需）
# ============================================================
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# ============================================================
# AI CLI 配置
# ============================================================
# 目标项目目录（用于 Claude Code CLI 和 Gemini CLI）
TARGET_PROJECT_DIR=E:\IdeaProjects\your-project

# AI 执行超时时间（秒），默认 600
AI_TIMEOUT=600

# ============================================================
# AI API 配置（可选，至少配置一个）
# ============================================================
# Claude API 密钥（https://console.anthropic.com/）
CLAUDE_API_KEY=your_claude_api_key_here

# Gemini API 密钥（https://aistudio.google.com/app/apikey）
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API 密钥（https://platform.openai.com/api-keys）
OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# 默认设置
# ============================================================
# 默认 AI 提供商：claude, gemini, openai
DEFAULT_PROVIDER=claude

# 默认执行层：api（快速响应）, cli（深度代码能力）
DEFAULT_LAYER=api

# ============================================================
# 会话管理配置
# ============================================================
# 会话存储路径
SESSION_STORAGE_PATH=./data/sessions.json

# 单个会话最大消息数（超过后自动创建新会话）
MAX_SESSION_MESSAGES=50

# 会话超时时间（秒），默认 86400（24小时）
SESSION_TIMEOUT=86400

# ============================================================
# 缓存配置
# ============================================================
# 消息去重缓存大小
CACHE_SIZE=1000

# ============================================================
# SSL 配置（可选）
# ============================================================
# SSL 证书文件路径（留空则使用 certifi）
SSL_CERT_FILE=

# ============================================================
# 日志配置
# ============================================================
# 日志级别：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# 测试配置（仅用于测试脚本）
# ============================================================
FEISHU_CHAT_ID=your_chat_id_here
FEISHU_USER_ID=your_user_id_here
